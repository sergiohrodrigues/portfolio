generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PortfolioProfile {
  id        String   @id @default("main")
  locale    String   @default("pt")
  name      String
  role      String
  location  String
  avatarUrl String   @map("avatar_url")
  summary   String
  email     String
  github    String
  linkedin  String
  whatsapp  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([locale])
  @@map("portfolio_profiles")
}

model PortfolioAbout {
  id          String   @id @default("main")
  locale      String   @default("pt")
  headline    String
  description String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([locale])
  @@map("portfolio_about")
}

model PortfolioSkill {
  id        String   @id
  name      String
  category  String
  level     Int
  order     Int      @default(0) @map("display_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("portfolio_skills")
}

model PortfolioStudy {
  id        String   @id
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("portfolio_studies")
}

model PortfolioReadBook {
  id        String   @id
  locale    String   @default("pt")
  name      String
  imageUrl  String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([locale])
  @@map("portfolio_read_books")
}

model PortfolioReadingBook {
  id        String   @id
  locale    String   @default("pt")
  name      String
  imageUrl  String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([locale])
  @@map("portfolio_reading_books")
}

model PortfolioLanguage {
  id        String   @id
  locale    String   @default("pt")
  name      String
  level     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([locale])
  @@map("portfolio_languages")
}

model PortfolioProject {
  id          String   @id
  locale      String   @default("pt")
  title       String
  description String
  stack       String
  link        String   @default("")
  repo        String   @default("")
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([locale])
  @@map("portfolio_projects")
}

model PortfolioExperience {
  id          String   @id
  locale      String   @default("pt")
  role        String
  company     String
  period      String
  description String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([locale])
  @@map("portfolio_experiences")
}
